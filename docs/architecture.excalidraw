    {
      "id": "flow-desc",
      "type": "text",
      "x": 250,
      "y": 925,
      "width": 540,
      "height": 20,
      "text": "tree → structure overview  |  map → AST skeletons (no bodies)  |  drill → surgical symbol read  |  search → cross-file symbol find",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
